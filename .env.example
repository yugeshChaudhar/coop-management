# Server Configuration
PORT=3001
JWT_SECRET=cooperative-secret-key-2024

# PostgreSQL Database Configuration (using connection string)
# Format: postgresql://user:password@host:port/database
# Example for local: postgresql://postgres:postgres@localhost:5432/cooperative
# Example for cloud (e.g., Render, Neon, Supabase): postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cooperative

# To use PostgreSQL:
# 1. Install PostgreSQL from https://www.postgresql.org/download/
# 2. Create a database named 'cooperative':
#    createdb cooperative
# 3. Copy this file to .env and update the DATABASE_URL:
#    copy .env.example .env
# 4. Run: npm install
# 5. Run: npm start
